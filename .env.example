# ---------------------------------------------------------------------------
# Frontend (Vite) — copy to .env.local and fill in. Safe to expose in browser.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ---------------------------------------------------------------------------
# Supabase Edge Function secrets (set with: supabase secrets set KEY=value)
# These are NEVER exposed to the browser.
# ---------------------------------------------------------------------------
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co        # auto-provided in functions
# SUPABASE_ANON_KEY=your-anon-public-key               # auto-provided in functions
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key      # auto-provided in functions
# STRIPE_SECRET_KEY=sk_live_or_test_xxx
# RESEND_API_KEY=re_xxx
# RESEND_FROM=bookings@yourdomain.com                  # a Resend-verified sender

# ---------------------------------------------------------------------------
# Data migration script (scripts/migrate-from-base44.mjs) — shell env only.
# ---------------------------------------------------------------------------
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
